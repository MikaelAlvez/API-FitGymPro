generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PERSONAL
  STUDENT
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  cpf             String           @unique
  phone           String
  password        String
  role            Role
  avatar          String?
  active          Boolean          @default(true)
  cep             String?
  street          String?
  number          String?
  neighborhood    String?
  city            String?
  state           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  personalId      String?
  personal        User?            @relation("PersonalStudents", fields: [personalId], references: [id])
  students        User[]           @relation("PersonalStudents")
  studentProfile  StudentProfile?
  personalProfile PersonalProfile?
  refreshTokens   RefreshToken[]

  sentRequests     PersonalRequest[] @relation("StudentRequests")
  receivedRequests PersonalRequest[] @relation("PersonalRequests")

  personalWorkouts Workout[] @relation("PersonalWorkouts")
  studentWorkouts  Workout[] @relation("StudentWorkouts")

  studentSessions WorkoutSession[] @relation("StudentSessions")

  @@map("users")
}

model StudentProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sex          String
  birthDate    String
  weight       String
  height       String
  goal         String
  focusMuscle  String
  experience   String
  gymType      String
  cardio       String
  trainingDays String[]

  @@map("student_profiles")
}

model PersonalProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sex            String
  birthDate      String
  weight         String?
  height         String?
  course         String
  university     String
  educationLevel String
  cref           String
  classFormat    String
  availableDays  String[]

  @@map("personal_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model PersonalRequest {
  id         String        @id @default(uuid())
  studentId  String
  personalId String
  status     RequestStatus @default(PENDING)
  message    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  student  User @relation("StudentRequests", fields: [studentId], references: [id], onDelete: Cascade)
  personal User @relation("PersonalRequests", fields: [personalId], references: [id], onDelete: Cascade)

  @@unique([studentId, personalId])
  @@map("personal_requests")
}

model Workout {
  id         String   @id @default(uuid())
  name       String
  days       String[]
  notes      String?
  personalId String?
  studentId  String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  personal  User?            @relation("PersonalWorkouts", fields: [personalId], references: [id], onDelete: SetNull)
  student   User             @relation("StudentWorkouts", fields: [studentId], references: [id], onDelete: Cascade)
  exercises Exercise[]
  sessions  WorkoutSession[]

  @@map("workouts")
}

model Exercise {
  id         String  @id @default(uuid())
  name       String
  sets       String
  reps       String
  order      Int     @default(0)
  type       String  @default("exercise")
  groupId    String?
  groupLabel String?
  duration   String?
  load       String?
  restTime   String?
  workoutId  String
  workout    Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@map("exercises")
}

model WorkoutSession {
  id         String    @id @default(uuid())
  workoutId  String
  studentId  String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  duration   Int?
  caption    String
  captionEnd String?
  notes      String?
  notesEnd   String?
  location   String?
  photoStart String?
  photoEnd   String?

  workout       Workout               @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  student       User                  @relation("StudentSessions", fields: [studentId], references: [id], onDelete: Cascade)
  exercisesDone SessionExerciseDone[]

  @@map("workout_sessions")
}

model SessionExerciseDone {
  id         String @id @default(uuid())
  sessionId  String
  exerciseId String

  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, exerciseId])
  @@map("session_exercises_done")
}
