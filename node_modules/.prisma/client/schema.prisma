generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PERSONAL
  STUDENT
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  cpf             String           @unique
  phone           String
  password        String
  role            Role
  avatar          String?
  active          Boolean          @default(true)
  userCode        String?          @unique
  cep             String?
  street          String?
  number          String?
  neighborhood    String?
  city            String?
  state           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  personalId      String?
  personal        User?            @relation("PersonalStudents", fields: [personalId], references: [id])
  students        User[]           @relation("PersonalStudents")
  studentProfile  StudentProfile?
  personalProfile PersonalProfile?
  refreshTokens   RefreshToken[]

  sentRequests     PersonalRequest[] @relation("StudentRequests")
  receivedRequests PersonalRequest[] @relation("PersonalRequests")

  personalWorkouts Workout[] @relation("PersonalWorkouts")
  studentWorkouts  Workout[] @relation("StudentWorkouts")

  studentSessions WorkoutSession[] @relation("StudentSessions")

  sentFriendRequests     FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedFriendRequests")

  sessionLikes    SessionLike[]
  sessionComments SessionComment[]

  createdGroups     Group[]            @relation("CreatedGroups")
  groupMemberships  GroupMember[]
  challengeCheckins ChallengeCheckin[]

  @@map("users")
}

model StudentProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sex          String
  birthDate    String
  weight       String
  height       String
  goal         String
  focusMuscle  String
  experience   String
  gymType      String
  cardio       String
  trainingDays String[]

  @@map("student_profiles")
}

model PersonalProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sex            String
  birthDate      String
  weight         String?
  height         String?
  course         String
  university     String
  educationLevel String
  cref           String
  classFormat    String
  availableDays  String[]

  @@map("personal_profiles")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model PersonalRequest {
  id         String        @id @default(uuid())
  studentId  String
  personalId String
  status     RequestStatus @default(PENDING)
  message    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  student  User @relation("StudentRequests", fields: [studentId], references: [id], onDelete: Cascade)
  personal User @relation("PersonalRequests", fields: [personalId], references: [id], onDelete: Cascade)

  @@unique([studentId, personalId])
  @@map("personal_requests")
}

model Workout {
  id         String   @id @default(uuid())
  name       String
  days       String[]
  notes      String?
  personalId String?
  studentId  String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  personal  User?            @relation("PersonalWorkouts", fields: [personalId], references: [id], onDelete: SetNull)
  student   User             @relation("StudentWorkouts", fields: [studentId], references: [id], onDelete: Cascade)
  exercises Exercise[]
  sessions  WorkoutSession[]

  @@map("workouts")
}

model Exercise {
  id         String  @id @default(uuid())
  name       String
  sets       String
  reps       String
  order      Int     @default(0)
  type       String  @default("exercise")
  groupId    String?
  groupLabel String?
  duration   String?
  load       String?
  restTime   String?
  workoutId  String
  workout    Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@map("exercises")
}

model WorkoutSession {
  id         String    @id @default(uuid())
  workoutId  String
  studentId  String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  duration   Int?
  caption    String
  captionEnd String?
  notes      String?
  notesEnd   String?
  location   String?
  photoStart String?
  photoEnd   String?

  workout       Workout               @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  student       User                  @relation("StudentSessions", fields: [studentId], references: [id], onDelete: Cascade)
  exercisesDone SessionExerciseDone[]

  likes    SessionLike[]
  comments SessionComment[]

  @@map("workout_sessions")
}

model SessionExerciseDone {
  id         String @id @default(uuid())
  sessionId  String
  exerciseId String

  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, exerciseId])
  @@map("session_exercises_done")
}

model FriendRequest {
  id         String        @id @default(uuid())
  senderId   String
  receiverId String
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  sender   User @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("friend_requests")
}

model SessionLike {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  createdAt DateTime @default(now())

  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("session_likes")
}

model SessionComment {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session_comments")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  code        String   @unique // GRP-XXXXXX
  avatar      String?
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator    User             @relation("CreatedGroups", fields: [creatorId], references: [id], onDelete: Cascade)
  members    GroupMember[]
  challenges GroupChallenge[]

  @@map("groups")
}

model GroupMember {
  id       String          @id @default(uuid())
  groupId  String
  userId   String
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupChallenge {
  id          String   @id @default(uuid())
  groupId     String
  title       String
  description String?
  goal        Int // número de treinos alvo
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())

  group    Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkins ChallengeCheckin[]

  @@map("group_challenges")
}

model ChallengeCheckin {
  id          String   @id @default(uuid())
  challengeId String
  userId      String
  sessionId   String? // sessão de treino vinculada (opcional)
  note        String?
  checkedAt   DateTime @default(now())

  challenge GroupChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("challenge_checkins")
}

enum GroupMemberRole {
  OWNER
  MEMBER
}
